<% content_for :title, "Perfil — Gameficação" %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
    ⚙️ Configurações do Perfil
  </h1>

  <div class="rounded-2xl border shadow-sm p-6 mb-6
              bg-white border-gray-200 dark:bg-gray-800 dark:border-gray-700">
    <% if @user.errors.any? %>
      <div class="mb-4 p-3 rounded-xl bg-red-100 dark:bg-red-900/30 border border-red-300 dark:border-red-700
                  text-red-700 dark:text-red-400 text-sm">
        <% @user.errors.full_messages.each do |msg| %>
          <p>• <%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <%= form_with model: @user, url: profile_path, method: :patch, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :name, "Nome", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5" %>
        <%= f.text_field :name, required: true,
            class: "w-full px-4 py-3 rounded-xl border text-gray-900 dark:text-white
                    bg-gray-50 dark:bg-gray-900 border-gray-300 dark:border-gray-600
                    focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-colors" %>
      </div>

      <div>
        <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5" %>
        <%= f.email_field :email, required: true,
            class: "w-full px-4 py-3 rounded-xl border text-gray-900 dark:text-white
                    bg-gray-50 dark:bg-gray-900 border-gray-300 dark:border-gray-600
                    focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-colors" %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :password, "Nova Senha (opcional)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5" %>
          <%= f.password_field :password,
              class: "w-full px-4 py-3 rounded-xl border text-gray-900 dark:text-white
                      bg-gray-50 dark:bg-gray-900 border-gray-300 dark:border-gray-600
                      focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-colors" %>
        </div>
        <div>
          <%= f.label :password_confirmation, "Confirmar Senha", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5" %>
          <%= f.password_field :password_confirmation,
              class: "w-full px-4 py-3 rounded-xl border text-gray-900 dark:text-white
                      bg-gray-50 dark:bg-gray-900 border-gray-300 dark:border-gray-600
                      focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-colors" %>
        </div>
      </div>

      <!-- Theme selection -->
      <div class="border-t border-gray-200 dark:border-gray-700 pt-4">
        <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Aparência</p>
        <div class="grid grid-cols-2 gap-3 mb-4">
          <% User::THEMES.each do |t| %>
            <label class="flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition-colors
                          <%= @user.theme == t ? 'border-purple-500 bg-purple-50 dark:bg-purple-900/20' : 'border-gray-200 dark:border-gray-700 hover:border-gray-300 dark:hover:border-gray-600' %>">
              <%= f.radio_button :theme, t, class: "sr-only" %>
              <span class="text-2xl"><%= t == 'dark' ? '🌙' : '☀️' %></span>
              <span class="font-medium text-gray-900 dark:text-white capitalize"><%= t == 'dark' ? 'Escuro' : 'Claro' %></span>
            </label>
          <% end %>
        </div>

        <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Cor do Tema</p>
        <div class="grid grid-cols-3 sm:grid-cols-6 gap-2">
          <% User::COLOR_THEMES.each do |color| %>
            <label class="flex flex-col items-center gap-1 p-2 rounded-xl border cursor-pointer transition-colors
                          <%= @user.color_theme == color ? 'border-purple-500 bg-purple-50 dark:bg-purple-900/20' : 'border-gray-200 dark:border-gray-700' %>">
              <%= f.radio_button :color_theme, color, class: "sr-only" %>
              <span class="w-6 h-6 rounded-full border-2 border-white shadow-sm <%= color_dot_class(color) %>"></span>
              <span class="text-xs text-gray-600 dark:text-gray-400 capitalize"><%= color %></span>
            </label>
          <% end %>
        </div>
      </div>

      <%= f.submit "Salvar Alterações",
          class: "w-full py-3 rounded-xl font-bold text-white cursor-pointer transition-all mt-2
                  bg-gradient-to-r from-purple-600 to-pink-600
                  hover:from-purple-700 hover:to-pink-700 active:scale-95" %>
    <% end %>
  </div>
</div>
