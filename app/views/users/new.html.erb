<% content_for :title, "Criar conta — Gameficação" %>

<div class="min-h-screen flex items-center justify-center
            bg-gradient-to-br from-gray-900 via-purple-900 to-gray-900 px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <div class="text-6xl mb-3">⚔️</div>
      <h1 class="text-3xl font-black text-white mb-1">Crie seu Personagem</h1>
      <p class="text-purple-300 text-sm">Comece sua jornada de produtividade</p>
    </div>

    <div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-8 shadow-2xl">
      <% if @user.errors.any? %>
        <div class="mb-4 p-3 rounded-xl bg-red-500/20 border border-red-500/30 text-red-300 text-sm">
          <% @user.errors.full_messages.each do |msg| %>
            <p>• <%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <%= form_with model: @user, url: register_path, class: "space-y-4" do |f| %>
        <div>
          <%= f.label :name, "Nome de Herói", class: "block text-sm font-medium text-purple-200 mb-1.5" %>
          <%= f.text_field :name, required: true,
              class: "w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white
                      placeholder-white/40 focus:outline-none focus:border-purple-400 focus:ring-1
                      focus:ring-purple-400 transition-colors",
              placeholder: "Seu nome épico" %>
        </div>

        <div>
          <%= f.label :email, "Email", class: "block text-sm font-medium text-purple-200 mb-1.5" %>
          <%= f.email_field :email, required: true,
              class: "w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white
                      placeholder-white/40 focus:outline-none focus:border-purple-400 focus:ring-1
                      focus:ring-purple-400 transition-colors",
              placeholder: "seu@email.com" %>
        </div>

        <div>
          <%= f.label :password, "Senha (mín. 12 caracteres)", class: "block text-sm font-medium text-purple-200 mb-1.5" %>
          <%= f.password_field :password, required: true, minlength: 12,
              class: "w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white
                      placeholder-white/40 focus:outline-none focus:border-purple-400 focus:ring-1
                      focus:ring-purple-400 transition-colors",
              placeholder: "••••••••••••" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirmar Senha", class: "block text-sm font-medium text-purple-200 mb-1.5" %>
          <%= f.password_field :password_confirmation, required: true,
              class: "w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white
                      placeholder-white/40 focus:outline-none focus:border-purple-400 focus:ring-1
                      focus:ring-purple-400 transition-colors",
              placeholder: "••••••••••••" %>
        </div>

        <%= f.submit "Iniciar Aventura! 🎮",
            class: "w-full py-3 rounded-xl font-bold text-white cursor-pointer transition-all
                    bg-gradient-to-r from-purple-600 to-pink-600
                    hover:from-purple-700 hover:to-pink-700 hover:shadow-lg hover:shadow-purple-500/25
                    active:scale-95" %>
      <% end %>

      <div class="mt-6 text-center text-sm text-purple-300">
        Já tem conta?
        <%= link_to "Entrar →", login_path,
            class: "text-white font-semibold hover:text-purple-200 transition-colors" %>
      </div>
    </div>
  </div>
</div>
