<div id="task-counts" class="flex items-center gap-4 text-sm">
  <span class="flex items-center gap-1.5 text-yellow-600 dark:text-yellow-400 font-medium">
    <span>⏳</span> <%= pending %> pendentes
  </span>
  <span class="text-gray-300 dark:text-gray-600">|</span>
  <span class="flex items-center gap-1.5 text-green-600 dark:text-green-400 font-medium">
    <span>✅</span> <%= completed %> concluídas
  </span>
</div>
