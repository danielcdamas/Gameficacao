<% content_for :title, "Editar Tarefa — Gameficação" %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to tasks_path, class: "text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200" do %>
      ← Voltar
    <% end %>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Editar Missão</h1>
  </div>

  <div class="rounded-2xl border shadow-sm p-6
              bg-white border-gray-200 dark:bg-gray-800 dark:border-gray-700">
    <%= render "tasks/form", task: @task %>
  </div>
</div>
