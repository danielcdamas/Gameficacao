<% border_class = difficulty_border_class(task.difficulty) %>
<% badge_class  = difficulty_badge_class(task.difficulty) %>

<div id="task-<%= task.id %>"
     class="group relative flex items-start gap-3 p-4 rounded-xl border transition-all duration-300
            <%= task.completed? ? 'opacity-60 bg-gray-50 dark:bg-gray-900/30 border-gray-100 dark:border-gray-800' :
                                  'bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700 hover:border-gray-300 dark:hover:border-gray-600 hover:shadow-sm' %>"
     data-difficulty="<%= task.difficulty %>">

  <!-- Complete button or completed indicator -->
  <% if task.completed? %>
    <div class="mt-0.5 flex-shrink-0 w-6 h-6 rounded-full bg-green-500 flex items-center justify-center">
      <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
      </svg>
    </div>
  <% else %>
    <%= button_to complete_task_path(task), method: :patch,
        class: "mt-0.5 flex-shrink-0 w-6 h-6 rounded-full border-2 transition-all cursor-pointer #{border_class} hover:opacity-80 active:scale-90" do %>
      <span class="sr-only">Completar</span>
    <% end %>
  <% end %>

  <!-- Task content -->
  <div class="flex-1 min-w-0">
    <div class="flex items-start justify-between gap-2">
      <p class="font-medium text-gray-900 dark:text-white truncate
                <%= 'line-through text-gray-400 dark:text-gray-500' if task.completed? %>">
        <%= task.title %>
      </p>
      <div class="flex items-center gap-2 flex-shrink-0">
        <!-- XP badge -->
        <span class="text-xs font-bold px-2 py-0.5 rounded-full <%= badge_class %>">
          <%= task.difficulty_emoji %> +<%= task.xp_reward %> XP
        </span>
        <!-- Actions on hover -->
        <% unless task.completed? %>
          <div class="opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-1">
            <%= link_to edit_task_path(task),
                class: "p-1 rounded-md text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
            <% end %>
            <%= button_to task_path(task), method: :delete,
                data: { turbo_confirm: "Excluir esta tarefa?" },
                class: "p-1 rounded-md text-gray-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex items-center flex-wrap gap-x-3 gap-y-0.5 mt-1">
      <span class="text-xs text-gray-400 dark:text-gray-500 capitalize"><%= task.difficulty_label %></span>
      <span class="text-gray-300 dark:text-gray-600">·</span>
      <span class="text-xs text-gray-400 dark:text-gray-500 capitalize"><%= task.category %></span>
      <% if task.due_date %>
        <span class="text-gray-300 dark:text-gray-600">·</span>
        <span class="text-xs <%= task.due_date < Date.current && !task.completed? ? 'text-red-500 font-medium' : 'text-gray-400 dark:text-gray-500' %>">
          <%= task.due_date.strftime("%d/%m/%Y") %>
        </span>
      <% end %>
      <% if task.completed? && task.completed_at %>
        <span class="text-gray-300 dark:text-gray-600">·</span>
        <span class="text-xs text-green-600 dark:text-green-400">Concluída <%= time_ago_in_words(task.completed_at) %> atrás</span>
      <% end %>
    </div>

    <% if task.description.present? %>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 line-clamp-2"><%= task.description %></p>
    <% end %>
  </div>
</div>
