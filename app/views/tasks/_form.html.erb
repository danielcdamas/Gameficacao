<div id="new-task-form">
  <%= form_with model: task, url: task.new_record? ? tasks_path : task_path(task),
      class: "space-y-3", data: { controller: "task-form" } do |f| %>

    <% if task.errors.any? %>
      <div class="p-3 rounded-lg bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 text-sm">
        <% task.errors.full_messages.each do |msg| %>
          <p>• <%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div class="flex gap-3">
      <%= f.text_field :title, required: true,
          placeholder: "Nova missão...",
          class: "flex-1 px-4 py-2.5 rounded-xl border text-gray-900 dark:text-white
                  bg-gray-50 dark:bg-gray-900 border-gray-300 dark:border-gray-600
                  placeholder-gray-400 dark:placeholder-gray-500
                  focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-colors" %>

      <!-- Difficulty selector -->
      <div class="relative" data-controller="dropdown">
        <button type="button" data-action="click->dropdown#toggle"
                data-task-form-target="difficultyBtn"
                class="flex items-center gap-1.5 px-3 py-2.5 rounded-xl border text-sm font-medium transition-colors
                       border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300
                       bg-gray-50 dark:bg-gray-900 hover:bg-gray-100 dark:hover:bg-gray-800">
          <span data-task-form-target="difficultyLabel">⚡ Fácil</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div data-dropdown-target="menu"
             class="hidden absolute right-0 mt-1 w-40 rounded-xl shadow-lg border py-1 z-10
                    bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700">
          <% Task::DIFFICULTIES.each do |key, info| %>
            <button type="button"
                    data-action="click->task-form#selectDifficulty click->dropdown#close"
                    data-difficulty="<%= key %>"
                    data-label="<%= info[:emoji] %> <%= info[:label] %>"
                    class="w-full text-left px-3 py-2 text-sm hover:bg-gray-100 dark:hover:bg-gray-700
                           text-gray-700 dark:text-gray-300 transition-colors flex items-center gap-2">
              <span><%= info[:emoji] %></span>
              <span><%= info[:label] %></span>
              <span class="ml-auto text-xs text-gray-400">+<%= info[:xp] %> XP</span>
            </button>
          <% end %>
        </div>
      </div>
    </div>

    <div class="flex gap-3">
      <!-- Category -->
      <%= f.select :category, Task::CATEGORIES.map { |c| [c.capitalize, c] },
          { selected: task.category || "geral" },
          class: "flex-1 px-3 py-2.5 rounded-xl border text-sm text-gray-700 dark:text-gray-300
                  bg-gray-50 dark:bg-gray-900 border-gray-300 dark:border-gray-600
                  focus:outline-none focus:border-purple-500 transition-colors" %>

      <!-- Due date -->
      <%= f.date_field :due_date,
          class: "flex-1 px-3 py-2.5 rounded-xl border text-sm text-gray-700 dark:text-gray-300
                  bg-gray-50 dark:bg-gray-900 border-gray-300 dark:border-gray-600
                  focus:outline-none focus:border-purple-500 transition-colors" %>
    </div>

    <!-- Hidden difficulty field -->
    <%= f.hidden_field :difficulty, value: task.difficulty || "facil", data: { task_form_target: "difficulty" } %>

    <!-- Description (collapsible) -->
    <details class="group">
      <summary class="text-sm text-gray-500 dark:text-gray-400 cursor-pointer hover:text-gray-700 dark:hover:text-gray-300 select-none">
        + Adicionar descrição
      </summary>
      <div class="mt-2">
        <%= f.text_area :description, rows: 2,
            placeholder: "Detalhes opcionais...",
            class: "w-full px-4 py-2.5 rounded-xl border text-sm text-gray-900 dark:text-white
                    bg-gray-50 dark:bg-gray-900 border-gray-300 dark:border-gray-600
                    placeholder-gray-400 dark:placeholder-gray-500
                    focus:outline-none focus:border-purple-500 transition-colors resize-none" %>
      </div>
    </details>

    <div class="flex justify-end">
      <%= f.submit task.new_record? ? "Adicionar Missão ⚡" : "Salvar",
          class: "px-6 py-2.5 rounded-xl font-bold text-sm text-white cursor-pointer transition-all
                  bg-gradient-to-r from-purple-600 to-pink-600
                  hover:from-purple-700 hover:to-pink-700 active:scale-95" %>
    </div>
  <% end %>
</div>
