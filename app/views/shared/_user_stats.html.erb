<div class="hidden sm:flex items-center gap-3">
  <!-- Level badge -->
  <div class="flex items-center gap-1.5">
    <span class="px-2 py-0.5 text-xs font-bold rounded-full bg-purple-100 text-purple-700 dark:bg-purple-900/50 dark:text-purple-300">
      Nv.<%= user.level %>
    </span>
    <span class="text-xs text-gray-500 dark:text-gray-400 hidden lg:block"><%= user.title %></span>
  </div>

  <!-- XP bar -->
  <div class="hidden md:flex flex-col gap-0.5 w-28">
    <div class="flex justify-between text-xs text-gray-500 dark:text-gray-400">
      <span><%= user.xp %> XP</span>
      <span>-<%= user.xp_to_next_level %></span>
    </div>
    <div class="h-1.5 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
      <div class="h-full rounded-full transition-all duration-500 bg-gradient-to-r from-purple-500 to-pink-500"
           style="width: <%= user.xp_progress_percent %>%"></div>
    </div>
  </div>

  <!-- Streak -->
  <% if user.streak_days > 0 %>
    <div class="flex items-center gap-1 text-orange-500 dark:text-orange-400">
      <span class="text-sm">🔥</span>
      <span class="text-xs font-bold"><%= user.streak_days %>d</span>
    </div>
  <% end %>
</div>
