<nav class="fixed top-0 left-0 right-0 z-40 border-b backdrop-blur-sm
            bg-white/90 border-gray-200
            dark:bg-gray-900/90 dark:border-gray-700"
     data-controller="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <div class="flex items-center gap-3">
        <%= link_to root_path, class: "flex items-center gap-2 group" do %>
          <span class="text-2xl">🎮</span>
          <span class="font-bold text-xl text-gray-900 dark:text-white group-hover:text-purple-500 transition-colors">
            Gameficação
          </span>
        <% end %>
      </div>

      <!-- Nav Links -->
      <div class="hidden md:flex items-center gap-1">
        <%= link_to "Dashboard", root_path,
            class: "px-3 py-2 rounded-lg text-sm font-medium transition-colors
                    text-gray-600 hover:text-gray-900 hover:bg-gray-100
                    dark:text-gray-300 dark:hover:text-white dark:hover:bg-gray-800" %>
        <%= link_to "Tarefas", tasks_path,
            class: "px-3 py-2 rounded-lg text-sm font-medium transition-colors
                    text-gray-600 hover:text-gray-900 hover:bg-gray-100
                    dark:text-gray-300 dark:hover:text-white dark:hover:bg-gray-800" %>
        <%= link_to "Conquistas", achievements_path,
            class: "px-3 py-2 rounded-lg text-sm font-medium transition-colors
                    text-gray-600 hover:text-gray-900 hover:bg-gray-100
                    dark:text-gray-300 dark:hover:text-white dark:hover:bg-gray-800" %>
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <!-- Theme Toggle -->
        <div class="flex items-center gap-1 p-1 rounded-lg bg-gray-100 dark:bg-gray-800">
          <%= button_to theme_path, method: :patch,
              params: { theme: "light" },
              class: "p-1.5 rounded-md transition-colors #{ @theme == 'light' ? 'bg-white dark:bg-gray-700 shadow-sm' : 'hover:bg-white/50 dark:hover:bg-gray-700/50' }",
              title: "Tema claro" do %>
            ☀️
          <% end %>
          <%= button_to theme_path, method: :patch,
              params: { theme: "dark" },
              class: "p-1.5 rounded-md transition-colors #{ @theme == 'dark' ? 'bg-white dark:bg-gray-700 shadow-sm' : 'hover:bg-white/50 dark:hover:bg-gray-700/50' }",
              title: "Tema escuro" do %>
            🌙
          <% end %>
        </div>

        <!-- Color Theme Picker -->
        <div class="relative" data-controller="dropdown">
          <button data-action="click->dropdown#toggle"
                  class="p-2 rounded-lg text-gray-600 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-800 transition-colors"
                  title="Cor do tema">
            🎨
          </button>
          <div data-dropdown-target="menu"
               class="hidden absolute right-0 mt-2 w-48 rounded-xl shadow-lg border
                      bg-white border-gray-200
                      dark:bg-gray-800 dark:border-gray-700 p-2">
            <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 px-2 pb-1">Cor do Tema</p>
            <div class="grid grid-cols-3 gap-1">
              <% User::COLOR_THEMES.each do |color| %>
                <%= button_to theme_path, method: :patch,
                    params: { color_theme: color },
                    class: "flex flex-col items-center gap-1 p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors",
                    title: color.capitalize do %>
                  <span class="w-5 h-5 rounded-full border-2 border-white shadow-sm
                               <%= color_dot_class(color) %>"></span>
                  <span class="text-xs text-gray-600 dark:text-gray-300 capitalize"><%= color %></span>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>

        <!-- User info & XP bar -->
        <div id="user-stats">
          <%= render "shared/user_stats", user: current_user %>
        </div>

        <!-- User menu -->
        <div class="relative" data-controller="dropdown">
          <button data-action="click->dropdown#toggle"
                  class="flex items-center gap-2 px-3 py-1.5 rounded-lg transition-colors
                         text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white font-bold text-sm">
              <%= current_user.name.first.upcase %>
            </div>
            <span class="hidden sm:block text-sm font-medium"><%= current_user.name.split.first %></span>
          </button>
          <div data-dropdown-target="menu"
               class="hidden absolute right-0 mt-2 w-48 rounded-xl shadow-lg border
                      bg-white border-gray-200
                      dark:bg-gray-800 dark:border-gray-700 py-1">
            <%= link_to edit_profile_path,
                class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700" do %>
              ⚙️ <span>Perfil</span>
            <% end %>
            <%= button_to logout_path, method: :delete,
                class: "w-full flex items-center gap-2 px-4 py-2 text-sm text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/20" do %>
              🚪 <span>Sair</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>
