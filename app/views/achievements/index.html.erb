<% content_for :title, "Conquistas — Gameficação" %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
      🏆 Conquistas
    </h1>
    <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">
      <%= @earned_ids.size %> de <%= @all_achievements.count %> desbloqueadas
    </p>
    <!-- Progress bar -->
    <div class="mt-3 h-2.5 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden max-w-xs">
      <div class="h-full bg-gradient-to-r from-yellow-400 to-orange-500 rounded-full transition-all"
           style="width: <%= @all_achievements.count > 0 ? (@earned_ids.size.to_f / @all_achievements.count * 100).round : 0 %>%"></div>
    </div>
  </div>

  <% Achievement::RARITIES.each do |rarity| %>
    <% group = @all_achievements.select { |a| a.rarity == rarity } %>
    <% next if group.empty? %>

    <div class="mb-8">
      <h2 class="text-sm font-bold uppercase tracking-wider mb-3 flex items-center gap-2
                 <%= rarity_text_class(rarity) %>">
        <%= rarity_star(rarity) %> <%= rarity.capitalize %>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% group.each do |achievement| %>
          <% earned = @earned_ids.include?(achievement.id) %>
          <div class="rounded-2xl border p-4 transition-all
                      <%= earned ?
                          'bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700 shadow-sm' :
                          'bg-gray-50 dark:bg-gray-900 border-gray-200 dark:border-gray-800 opacity-60' %>">
            <div class="flex items-start gap-3">
              <div class="text-4xl <%= earned ? '' : 'grayscale opacity-50' %>">
                <%= achievement.icon %>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-1">
                  <h3 class="font-bold text-sm text-gray-900 dark:text-white leading-tight">
                    <%= achievement.name %>
                  </h3>
                  <% if earned %>
                    <span class="text-green-500 flex-shrink-0">✓</span>
                  <% end %>
                </div>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5"><%= achievement.description %></p>
                <div class="flex items-center gap-2 mt-2">
                  <span class="text-xs font-bold px-2 py-0.5 rounded-full
                               <%= rarity_badge_class(rarity) %>">
                    <%= rarity.capitalize %>
                  </span>
                  <span class="text-xs text-purple-600 dark:text-purple-400 font-medium">
                    +<%= achievement.xp_bonus %> XP
                  </span>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
